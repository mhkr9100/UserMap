# ── Root Vite app environment variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# For server-specific vars, see apps/server/.env.example

VITE_AUTH_POOL_ID="your-auth-pool-id"
VITE_AUTH_CLIENT_ID="your-auth-client-id"
VITE_API_BASE_URL="https://your-api.example.com"

# ── Phase 1: Local API Server ─────────────────────────────────────────────────
# Port for the local API server (default: 5185)
# Also configure apps/server/.env with these values.
PORT=5185
APP_URL=http://localhost:5185

# ── Phase 2: Tool Integrations ────────────────────────────────────────────────

# Slack OAuth App credentials
# Create an app at https://api.slack.com/apps and enable OAuth & Permissions.
# Add redirect URI: http://localhost:3000/oauth/callback/slack
# Required scopes: channels:history, channels:read, users:read
VITE_SLACK_CLIENT_ID="your-slack-client-id"
VITE_SLACK_CLIENT_SECRET="your-slack-client-secret"

# GitHub OAuth App credentials
# Create an OAuth App at https://github.com/settings/developers.
# Add redirect URI: http://localhost:3000/oauth/callback/github
# Alternatively, users can use a Personal Access Token (PAT) via the UI.
VITE_GITHUB_CLIENT_ID="your-github-client-id"
VITE_GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth 2.0 credentials (Gmail)
# Create credentials at https://console.cloud.google.com/apis/credentials.
# Add redirect URI: http://localhost:3000/oauth/callback/gmail
# Required scopes: gmail.readonly, userinfo.email
VITE_GOOGLE_CLIENT_ID="your-google-client-id"
VITE_GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Phase 4: AI Integrations ──────────────────────────────────────────────────
# AI API keys are entered through the UserMap UI and stored in localStorage.
# No environment variables are required for ChatGPT, Claude, or Gemini —
# users paste their keys in the Tools panel > AI Assistants section.

# Ollama (Local LLM) — optional override if Ollama is not on localhost:11434
# VITE_OLLAMA_URL="http://localhost:11434"

# Claude CORS proxy — only needed in browser dev mode if Anthropic blocks direct
# browser requests. Leave empty to call the Anthropic API directly (default for
# Tauri desktop builds and most dev setups).
# VITE_CLAUDE_PROXY_URL=""
