# ── UserMap local API server ──────────────────────────────────────────────────
# Port for the local API server (default: 5185)
PORT=5185

# Public base URL of the server (used in links / CORS)
APP_URL=http://localhost:5185

# ── Slack OAuth app credentials ───────────────────────────────────────────────
# Create a Slack app at https://api.slack.com/apps and add these values.
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:5185/api/connect/slack/callback

# ── Optional ──────────────────────────────────────────────────────────────────
# Override where UserMap stores its SQLite database (default: ~/.usermap)
# USERMAP_DATA_DIR=/path/to/custom/dir
