{
  "name": "usermap-root",
  "private": true,
  "version": "0.1.0",
  "main": "electron/main.js",
  "type": "module",
  "workspaces": [
    "apps/server",
    "apps/desktop"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "dev:app": "concurrently -k \"vite\" \"wait-on tcp:3000 && cross-env NODE_ENV=development electron .\"",
    "build:app": "npm run build && electron-builder",
    "dev:server": "npm run dev --workspace=apps/server",
    "build:server": "npm run build --workspace=apps/server",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "gen:manifest": "node scripts/make-manifest.mjs",
    "gen:bundle": "node scripts/make-bundle.mjs",
    "gen:all": "npm run gen:manifest && npm run gen:bundle"
  },
  "dependencies": {
    "amazon-cognito-identity-js": "^6.3.12",
    "framer-motion": "^11.18.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.475.0",
    "motion": "^11.18.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^6.3.3",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.usermap.app",
    "productName": "UserMap",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
