{
  "name": "usermap-root",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/server",
    "apps/desktop"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "dev:server": "npm run dev --workspace=apps/server",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "build:server": "npm run build --workspace=apps/server",
    "build:desktop": "npm run build --workspace=apps/desktop"
  },
  "dependencies": {
    "amazon-cognito-identity-js": "^6.3.12",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.475.0",
    "motion": "^11.18.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/node": "^22.15.3",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^6.3.3"
  }
}
